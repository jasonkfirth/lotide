            pid="$(cat "${pid_file}")"
            if kill -0 "${pid}" >/dev/null 2>&1; then
                kill "${pid}" >/dev/null 2>&1 || true
            fi
            rm -f "${pid_file}"
        fi
    done
}

require_tool lotide
require_tool hitide
require_tool lotide-haiku-initdb
require_tool psql

lotide-haiku-initdb
write_default_env_files

sql_literal() {
    printf "'%s'" "$(printf '%s' "$1" | sed "s/'/''/g")"
}

apply_packaged_migrations() {
    local migration tag already_applied

    [ -d "${MIGRATIONS_DIR}" ] || die "missing packaged migrations: ${MIGRATIONS_DIR}"

    PGPASSWORD="${DB_PASSWORD}" psql \
        -h 127.0.0.1 \
        -p "${PGPORT}" \
        -U "${DB_USER}" \
        -d "${DB_NAME}" \
        -v ON_ERROR_STOP=1 \
        -c "CREATE TABLE IF NOT EXISTS haiku_applied_migrations (tag text PRIMARY KEY, applied_at timestamptz NOT NULL DEFAULT now())"
    PGPASSWORD="${DB_PASSWORD}" psql \
        -h 127.0.0.1 \
        -p "${PGPORT}" \
        -U "${DB_USER}" \
        -d "${DB_NAME}" \
        -v ON_ERROR_STOP=1 \
        -c "CREATE TABLE IF NOT EXISTS __migrant_migrations (tag text unique)"

    for migration in "${MIGRATIONS_DIR}"/*; do
        [ -f "${migration}/up.sql" ] || continue
        tag="$(basename "${migration}")"

        case "${tag}" in
            *[!abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_-]*)
                die "unexpected migration tag: ${tag}"
                ;;
        esac

        already_applied="$(
            PGPASSWORD="${DB_PASSWORD}" psql \
                -h 127.0.0.1 \
                -p "${PGPORT}" \
                -U "${DB_USER}" \
                -d "${DB_NAME}" \
                -tAc "SELECT 1 FROM haiku_applied_migrations WHERE tag = $(sql_literal "${tag}")"
        )"

        if [ "${already_applied}" = "1" ]; then
            PGPASSWORD="${DB_PASSWORD}" psql \
                -h 127.0.0.1 \
                -p "${PGPORT}" \
                -U "${DB_USER}" \
                -d "${DB_NAME}" \
                -v ON_ERROR_STOP=1 \
                -c "INSERT INTO __migrant_migrations (tag) VALUES ($(sql_literal "${tag}")) ON CONFLICT DO NOTHING"
            continue
        fi

        printf 'applying %s\n' "${tag}"
        PGPASSWORD="${DB_PASSWORD}" psql \
            -h 127.0.0.1 \
            -p "${PGPORT}" \
            -U "${DB_USER}" \
            -d "${DB_NAME}" \
            -v ON_ERROR_STOP=1 \
            -f "${migration}/up.sql"
        PGPASSWORD="${DB_PASSWORD}" psql \
            -h 127.0.0.1 \
            -p "${PGPORT}" \
            -U "${DB_USER}" \
            -d "${DB_NAME}" \
            -v ON_ERROR_STOP=1 \
            -c "INSERT INTO haiku_applied_migrations (tag) VALUES ($(sql_literal "${tag}"))"
        PGPASSWORD="${DB_PASSWORD}" psql \
            -h 127.0.0.1 \
            -p "${PGPORT}" \
            -U "${DB_USER}" \
            -d "${DB_NAME}" \
            -v ON_ERROR_STOP=1 \
            -c "INSERT INTO __migrant_migrations (tag) VALUES ($(sql_literal "${tag}")) ON CONFLICT DO NOTHING"
    done
}

apply_packaged_migrations

stop_existing_services

(
    set -a
    # shellcheck disable=SC1090
    . "${STATE_DIR}/lotide.env"
    set +a
    lotide
) >"${LOG_DIR}/lotide.log" 2>&1 &
printf '%s\n' "$!" >"${RUN_DIR}/lotide.pid"

(
    set -a
    # shellcheck disable=SC1090
    . "${STATE_DIR}/hitide.env"
    set +a
    hitide
) >"${LOG_DIR}/hitide.log" 2>&1 &
printf '%s\n' "$!" >"${RUN_DIR}/hitide.pid"

cat <<EOF_INNER
Lotide and Hitide are running locally.

  Lotide API: http://127.0.0.1:${LOTIDE_PORT}/api/unstable/instance
  Hitide UI : http://127.0.0.1:${HITIDE_PORT}/
  Settings  : ${STATE_DIR}
  Logs      : ${LOG_DIR}

Stop them with:
  lotide-haiku-stop
EOF_INNER

# end of lotide-haiku-run
EOF

