create_haiku_package() {
    local package_version stage_dir system_bin data_dir license_dir package_info hpkg_path pkg_path

    require_haiku
    require_tool package

    [ -x "$(lotide_bin)" ] || die "missing Lotide binary: $(lotide_bin)"
    [ -x "$(hitide_bin)" ] || die "missing Hitide binary: $(hitide_bin)"

    package_version="$(haiku_package_version)"
    stage_dir="${PACKAGE_WORK_DIR}/stage"
    system_bin="${stage_dir}/bin"
    data_dir="${stage_dir}/data/lotide"
    license_dir="${stage_dir}/data/licenses"
    package_info="${PACKAGE_WORK_DIR}/PackageInfo"
    hpkg_path="${PACKAGE_OUT_DIR}/lotide_haiku-${package_version}-$(haiku_package_architecture).hpkg"
    pkg_path="${PACKAGE_OUT_DIR}/lotide_haiku-${package_version}-$(haiku_package_architecture).pkg"

    rm -rf "${stage_dir}"
    mkdir -p "${system_bin}" "${data_dir}" "${license_dir}" "${PACKAGE_OUT_DIR}"

    cp "$(lotide_bin)" "${system_bin}/lotide"
    cp "$(hitide_bin)" "${system_bin}/hitide"
    cp "${LOTIDE_DIR}/LICENSE" "${license_dir}/AGPL-3.0-or-later"
    cp -R "${LOTIDE_DIR}/migrations" "${data_dir}/migrations"
    chmod +x "${system_bin}/lotide" "${system_bin}/hitide"

    write_packaged_helper_scripts "${system_bin}" "${data_dir}"
    write_package_info "${package_info}" "${package_version}"

    info "Creating Haiku package ${hpkg_path}"
    package create -C "${stage_dir}" -i "${package_info}" "${hpkg_path}"

    #
    # Haiku package files normally use .hpkg. A .pkg copy is emitted because
    # some people use that name generically when asking for an installable
    # package artifact.
    #
    cp "${hpkg_path}" "${pkg_path}"

    printf '%s\n' "${hpkg_path}"
    printf '%s\n' "${pkg_path}"
}

