#
#     - production TLS setup
#     - service supervisor integration
#     - public reverse proxy configuration

set -euo pipefail

STATE_DIR="${LOTIDE_HAIKU_STATE_DIR:-/boot/home/config/settings/lotide}"
MEDIA_DIR="${LOTIDE_HAIKU_MEDIA_DIR:-/boot/home/config/non-packaged/data/lotide/media}"
