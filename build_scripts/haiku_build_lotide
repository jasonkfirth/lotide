#!/bin/bash
#
# Project: Lotide Haiku Runtime Support
# -------------------------------------
#
# File: lotide-haiku-run
#
# Purpose:
#
#     Start a small local Lotide and Hitide instance on Haiku.
#
# Responsibilities:
#
#     - ensure PostgreSQL is initialized
#     - write default local environment files when missing
#     - apply Lotide migrations
#     - start Lotide and Hitide with local media storage
#
