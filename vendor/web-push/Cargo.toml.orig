[package]
name = "web-push"
description = "Web push notification client with support for http-ece encryption and VAPID authentication."
version = "0.11.0"
authors = ["Julius de Bruijn <julius+github@nauk.io>", "Andrew Ealovega <Andrew@Ealovega.dev>"]
license = "Apache-2.0"
homepage = "https://github.com/pimeys/rust-web-push"
repository = "https://github.com/pimeys/rust-web-push"
documentation = "https://docs.rs/web-push/"
readme = "README.md"
keywords = ["web-push", "http-ece", "vapid"]
categories = ["web-programming", "asynchronous"]
rust-version = "1.91.1"
edition = "2021"

[features]
default = ["hyper-client"]
hyper-client = ["hyper", "hyper-tls", "hyper-util", "http-body-util", "bytes"] # use features = ["hyper-client"], default-features = false for about 300kb size decrease

[dependencies]
hyper = { version = "1", features = ["client", "http1"], optional = true }
hyper-tls = { version = "0.6", optional = true }
hyper-util = { version = "0.1", features = ["client-legacy", "http1", "tokio"], optional = true }
http-body-util = { version = "0.1", optional = true }
bytes = { version = "1", optional = true }
futures-lite = { version = "2.5.0", optional = true }
http = "1"
serde = "1.0"
serde_json = "1.0"
serde_derive = "1.0"
ece = "2.2"
p256 = { version = "0.13.2", features = ["ecdsa", "pem", "pkcs8"] }
pem = "3.0.4"
sec1_decode = "0.1.0"
chrono = "0.4"
log = "0.4"
async-trait = "0.1"
ct-codecs = "1.1.3"

[dev-dependencies]
regex = "1.5"
tokio = { version = "1", features = ["macros", "rt-multi-thread"] }
